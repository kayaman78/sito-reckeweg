# Organizzazione su ghcr.io (es. "miouser" o "miaorg")
GHCR_ORG=tuaorg

# Tag immagine (lascia latest o usa un hash di commit)
IMAGE_TAG=latest

# Percorso assoluto sul host dove vivono rimedi.json e data.js
DATA_PATH=/opt/reckeweg/data

# Porta esposta sull'host (solo loopback — nginx fa da proxy)
APP_PORT=3000
BIND_HOST=127.0.0.1
